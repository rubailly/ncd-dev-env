# ── OpenFn Lightning ─────────────────────────────────────────────────────────
OPENFN_ADMIN_EMAIL=admin@local.dev
OPENFN_ADMIN_PASSWORD=openfn_local_password
# Generate with: openssl rand -base64 64 | tr -d '\n'
OPENFN_SECRET_KEY_BASE=local_dev_secret_key_base_must_be_at_least_64_chars_long_xxxxxxxxxxx
# Generate with: openssl rand -base64 24 | tr -d '\n'
OPENFN_ENCRYPTION_KEY=local_dev_encryption_key_base64==
OPENFN_WORKER_SECRET=local_dev_worker_secret
OPENFN_DB_PASSWORD=openfn

# ── ERPNext ───────────────────────────────────────────────────────────────────
ERPNEXT_VERSION=v15
ERPNEXT_DB_ROOT_PASSWORD=erpnext_root
ERPNEXT_SITE=local.ebuzima
ERPNEXT_ADMIN_PASSWORD=admin
